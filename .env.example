# El frontend Angular NO usa .env en runtime.
# Las keys van en src/environments/environment.ts (dev) y environment.prod.ts (prod).
#
# Variables que debés completar en esos archivos:
#
# googleMapsApiKey  → console.cloud.google.com → Maps JavaScript API
#
# firebase.apiKey          \
# firebase.authDomain       |
# firebase.projectId        |→ console.firebase.google.com → Project settings → Web app
# firebase.storageBucket    |
# firebase.messagingSenderId|
# firebase.appId            |
# firebase.measurementId   /
